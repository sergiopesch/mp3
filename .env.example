# Optional overrides for the local extractor backend
# Defaults already point at the project-local venv and system ffmpeg.

# Absolute path to yt-dlp binary
YT_DLP_BIN=/home/sergiopesch/.local/share/mp3/yt-dlp-venv/bin/yt-dlp

# Absolute path to ffmpeg binary
FFMPEG_BIN=/usr/bin/ffmpeg

# How long extracted files are retained in tmp/ before opportunistic cleanup
EXTRACT_RETENTION_HOURS=24
